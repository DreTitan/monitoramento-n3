# ===============================================
# CONFIGURAÇÕES DO SUPABASE
# ===============================================
# Obtenha essas informações em: https://app.supabase.com > Settings > API

# URL do projeto Supabase
SUPABASE_URL=https://xxxxx.supabase.co

# Chave pública (anon key) - para operações do frontend
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (service role) - para operações do backend
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# String de conexão do banco (opcional, para algumas operações)
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@db.xxxxx.supabase.co:5432/postgres
